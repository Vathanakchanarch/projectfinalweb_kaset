<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title><%= title || 'Article' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .article-content h1,
      .article-content h2,
      .article-content h3,
      .article-content h4,
      .article-content h5,
      .article-content h6 {
        color: #0f172a;
        font-weight: 800;
        line-height: 1.2;
        margin-top: 1.75rem;
        margin-bottom: 1rem;
      }

      .article-content h1 { font-size: 2rem; }
      .article-content h2 { font-size: 1.75rem; }
      .article-content h3 { font-size: 1.5rem; }
      .article-content h4 { font-size: 1.25rem; }

      .article-content p {
        color: #334155;
        font-size: 1.1rem;
        line-height: 2rem;
        margin-bottom: 1.15rem;
      }

      .article-content ul,
      .article-content ol {
        margin: 1rem 0 1.25rem 1.5rem;
        color: #334155;
      }

      .article-content ul { list-style: disc; }
      .article-content ol { list-style: decimal; }

      .article-content li {
        margin-bottom: 0.6rem;
        font-size: 1.05rem;
        line-height: 1.9rem;
      }

      .article-content blockquote {
        border-left: 4px solid #22d3ee;
        background: #ecfeff;
        color: #0f172a;
        padding: 1rem 1.25rem;
        margin: 1.5rem 0;
        font-style: italic;
        border-radius: 0.5rem;
      }

      .article-content pre {
        background: #0f172a;
        color: #e2e8f0;
        padding: 1rem 1.25rem;
        border-radius: 0.75rem;
        overflow-x: auto;
        margin: 1.25rem 0;
      }

      .article-content code {
        background: #e2e8f0;
        color: #0f172a;
        padding: 0.15rem 0.4rem;
        border-radius: 0.35rem;
        font-size: 0.95em;
      }

      .article-content pre code {
        background: transparent;
        color: inherit;
        padding: 0;
      }

      .article-content a {
        color: #0891b2;
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .article-content hr {
        border: 0;
        border-top: 1px solid #cbd5e1;
        margin: 2rem 0;
      }
    </style>
  </head>

  <body class="bg-black text-slate-300">
    <div class="w-full border-b border-slate-800 bg-[#030b18]/95 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="text-2xl font-extrabold tracking-tight">
          <span class="text-white">KASET-</span>
          <span class="text-cyan-400">NEWS</span>
        </a>

        <div class="flex items-center gap-6 text-[10px] font-bold uppercase tracking-[0.2em]">
          <a href="/" class="text-slate-500 hover:text-white transition-colors">
            Dashboard
          </a>

          <% if (userRole === 'editor') { %>
            <a href="/articles/create" class="text-slate-500 hover:text-white transition-colors">
              Create Article
            </a>
          <% } %>

          <% if (userRole === 'admin') { %>
            <a href="/admin" class="text-slate-500 hover:text-white transition-colors">
              Admin
            </a>
          <% } %>

          <% if (userName) { %>
            <span class="text-slate-500">|</span>
            <span class="text-cyan-400">Hello, <%= userName %></span>
            <a href="/logout" class="text-slate-500 hover:text-white transition-colors">
              Logout
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-10">
      <div class="mb-6">
        <a href="/" class="text-cyan-400 hover:text-cyan-300 font-medium">
          ← Back to dashboard
        </a>
      </div>

      <div class="max-w-5xl">
        <div class="rounded-2xl border border-slate-200 bg-white p-8 md:p-10 shadow-lg">
          <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
            <span class="inline-flex items-center rounded-full border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 bg-slate-50">
              <%= article.category_name || 'Uncategorized' %>
            </span>

            <span class="text-sm text-slate-500">
              <%= article.published_at ? new Date(article.published_at).toLocaleString() : '' %>
            </span>
          </div>

          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight text-slate-900 mb-6">
            <%= article.title %>
          </h1>

          <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 border-b border-slate-200 pb-6 mb-8">
            <span>
              By <span class="font-semibold text-cyan-700"><%= article.author_name || 'Unknown Editor' %></span>
            </span>
          </div>

          <div class="article-content max-w-none">
            <%- articleHtml %>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>