<div class="flex flex-1 items-center justify-center min-h-screen px-6 py-12 bg-black">
  <div class="w-full max-w-[600px] border border-slate-800 p-12 md:p-16 bg-[#030b18] rounded-2xl text-gray-400 shadow-2xl shadow-black/40">
    <h1 class="text-[35px] font-extrabold tracking-tight text-white">
      Forgot Password
    </h1>

    <p class="text-sm tracking-[0.1em] text-slate-500 mt-4 uppercase">
       verify your email to reset your password
    </p>

    <% if (error) { %>
      <div class="mt-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="mt-6 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-300">
        <%= success %>
      </div>
    <% } %>

    <form class="mt-14 space-y-10" action="/forgot" method="POST">
      <div>
        <label for="email" class="block text-sm tracking-[0.35em] text-slate-500 mb-4 uppercase">
          Email Address
        </label>

        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          placeholder="you@kasetnews.com"
          value="<%= email || '' %>"
          class="w-full rounded-lg bg-transparent border border-slate-700 px-6 py-5 text-lg text-slate-300 outline-none focus:border-cyan-400 transition"
          required
        />
      </div>

      <div class="flex justify-end">
        <button
          type="submit"
          class="w-[150px] bg-cyan-500 text-black text-sm font-bold tracking-[0.3em] py-3 hover:bg-cyan-400 rounded-lg transition"
        >
          NEXT
        </button>
      </div>
    </form>
  </div>
</div>
