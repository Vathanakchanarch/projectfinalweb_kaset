<div class="flex flex-1 items-center justify-center min-h-screen px-6 py-12 bg-black">
  <div class="w-full max-w-[720px] border border-slate-800 p-12 md:p-16 bg-[#030b18] rounded-2xl shadow-2xl shadow-black/40">
    <div class="mb-10">
      <h1 class="text-5xl font-extrabold tracking-tight">
        <span class="text-white">KASET-</span>
        <span class="text-cyan-400">NEWS</span>
      </h1>

      <p class="text-sm tracking-[0.2em] text-slate-500 mt-4 uppercase">
        // Professional account registration
      </p>

      <p class="text-sm text-slate-500 mt-4 leading-7">
        Use a company email ending with
        <span class="text-cyan-400 font-semibold">@kasetnews.com</span>
        and a password with at least 8 characters, uppercase, lowercase, and number.
      </p>
    </div>

    <% if (error) { %>
      <div class="mt-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">
        <%= error %>
      </div>
    <% } %>

    <form class="mt-10 space-y-8" action="/create" method="POST">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm tracking-[0.3em] text-slate-500 mb-4 uppercase">
            First Name
          </label>
          <input
            type="text"
            name="firstName"
            placeholder="First name"
            value="<%= formData?.firstName || '' %>"
            class="w-full rounded-lg bg-transparent border border-slate-700 px-6 py-5 text-lg text-slate-300 outline-none focus:border-cyan-400 transition"
            required
          />
        </div>

        <div>
          <label class="block text-sm tracking-[0.3em] text-slate-500 mb-4 uppercase">
            Last Name
          </label>
          <input
            type="text"
            name="lastName"
            placeholder="Last name"
            value="<%= formData?.lastName || '' %>"
            class="w-full rounded-lg bg-transparent border border-slate-700 px-6 py-5 text-lg text-slate-300 outline-none focus:border-cyan-400 transition"
            required
          />
        </div>
      </div>

      <div>
        <label class="block text-sm tracking-[0.3em] text-slate-500 mb-4 uppercase">
          Email Address
        </label>
        <input
          type="email"
          name="email"
          placeholder="you@kasetnews.com"
          value="<%= formData?.email || '' %>"
          pattern="^[A-Za-z0-9._%+-]+@kasetnews\.com$"
          title="Use an email ending with @kasetnews.com"
          class="w-full rounded-lg bg-transparent border border-slate-700 px-6 py-5 text-lg text-slate-300 outline-none focus:border-cyan-400 transition"
          required
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm tracking-[0.3em] text-slate-500 mb-4 uppercase">
            Password
          </label>
          <input
            id="password"
            type="password"
            name="password"
            placeholder="At least 8 chars, upper, lower, number"
            pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$"
            title="Password must be at least 8 characters and include uppercase, lowercase, and a number."
            class="w-full rounded-lg bg-transparent border border-slate-700 px-6 py-5 text-lg text-slate-300 outline-none focus:border-cyan-400 transition"
            required
          />

          <div class="mt-3">
            <div class="flex items-center justify-between text-xs uppercase tracking-[0.2em] text-slate-500 mb-2">
              <span>Password Strength</span>
              <span id="passwordStrengthText" class="text-slate-500">Enter password</span>
            </div>

            <div class="w-full h-2 rounded-full bg-slate-800 overflow-hidden">
              <div
                id="passwordStrengthBar"
                class="h-full w-0 transition-all duration-300"
              ></div>
            </div>

            <p id="passwordHint" class="mt-3 text-sm text-slate-500 leading-6">
              Use at least 8 characters with uppercase, lowercase, and a number.
            </p>
          </div>
        </div>

        <div>
          <label class="block text-sm tracking-[0.3em] text-slate-500 mb-4 uppercase">
            Confirm Password
          </label>
          <input
            id="confirmPassword"
            type="password"
            name="confirmPassword"
            placeholder="Repeat password"
            class="w-full rounded-lg bg-transparent border border-slate-700 px-6 py-5 text-lg text-slate-300 outline-none focus:border-cyan-400 transition"
            required
          />

          <p id="confirmMessage" class="mt-3 text-sm text-slate-500"></p>
        </div>
      </div>

      <div>
        <label class="block text-sm tracking-[0.3em] text-slate-500 mb-4 uppercase">
          Role
        </label>
        <select
          name="role"
          class="w-full rounded-lg bg-transparent border border-slate-700 px-6 py-5 text-lg text-slate-300 outline-none focus:border-cyan-400 transition"
        >
          <option value="editor" <%= formData?.role === 'editor' ? 'selected' : '' %>>Editor</option>
          <option value="admin" <%= formData?.role === 'admin' ? 'selected' : '' %>>Admin</option>
        </select>
      </div>

      <button
        type="submit"
        class="w-full bg-cyan-500 text-black text-sm font-bold tracking-[0.3em] py-4 hover:bg-cyan-400 rounded-lg transition"
      >
        REGISTER ACCOUNT
      </button>
    </form>
  </div>
</div>

<script>
  const passwordInput = document.getElementById('password');
  const confirmPasswordInput = document.getElementById('confirmPassword');
  const strengthText = document.getElementById('passwordStrengthText');
  const strengthBar = document.getElementById('passwordStrengthBar');
  const passwordHint = document.getElementById('passwordHint');
  const confirmMessage = document.getElementById('confirmMessage');

  function getPasswordStrength(password) {
    let score = 0;

    if (password.length >= 8) score++;
    if (/[a-z]/.test(password)) score++;
    if (/[A-Z]/.test(password)) score++;
    if (/\d/.test(password)) score++;
    if (/[^A-Za-z0-9]/.test(password)) score++;

    if (!password.length) {
      return {
        label: 'Enter password',
        width: '0%',
        barClass: 'bg-transparent',
        textClass: 'text-slate-500',
        hint: 'Use at least 8 characters with uppercase, lowercase, and a number.'
      };
    }

    if (score <= 2) {
      return {
        label: 'Weak',
        width: '33%',
        barClass: 'bg-red-500',
        textClass: 'text-red-400',
        hint: 'Weak password. Add more length, uppercase, lowercase, and numbers.'
      };
    }

    if (score <= 4) {
      return {
        label: 'Medium',
        width: '66%',
        barClass: 'bg-yellow-400',
        textClass: 'text-yellow-300',
        hint: 'Medium password. Add more complexity for better security.'
      };
    }

    return {
      label: 'Strong',
      width: '100%',
      barClass: 'bg-green-500',
      textClass: 'text-green-400',
      hint: 'Strong password.'
    };
  }

  function updateStrength() {
    const password = passwordInput.value;
    const result = getPasswordStrength(password);

    strengthText.textContent = result.label;
    strengthText.className = result.textClass;
    strengthBar.className = `h-full transition-all duration-300 ${result.barClass}`;
    strengthBar.style.width = result.width;
    passwordHint.textContent = result.hint;
    passwordHint.className = `mt-3 text-sm leading-6 ${result.textClass}`;

    updateConfirmMessage();
  }

  function updateConfirmMessage() {
    const password = passwordInput.value;
    const confirmPassword = confirmPasswordInput.value;

    if (!confirmPassword) {
      confirmMessage.textContent = '';
      return;
    }

    if (password === confirmPassword) {
      confirmMessage.textContent = 'Passwords match';
      confirmMessage.className = 'mt-3 text-sm text-green-400';
    } else {
      confirmMessage.textContent = 'Passwords do not match';
      confirmMessage.className = 'mt-3 text-sm text-red-400';
    }
  }

  passwordInput.addEventListener('input', updateStrength);
  confirmPasswordInput.addEventListener('input', updateConfirmMessage);
</script>